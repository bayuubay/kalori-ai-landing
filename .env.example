# Telegram bot username (without @). Baked into the build (NEXT_PUBLIC_*).
NEXT_PUBLIC_BOT_USERNAME=kalori_ai_bot

# Public URL of the installable PWA (kalori-ai-pwa). Baked into the build.
NEXT_PUBLIC_PWA_URL=https://app.kaloriai.my.id

# kalori-ai-api base URL. Server-side only — fetches the public credit-pack
# catalog (GET /credit-packs). Defaults to http://localhost:3000.
API_BASE_URL=http://localhost:3000
